# ─── Server Settings ────────────────────────────────────────
PORT=4000
NODE_ENV=development                      # Change to 'production' on GCE/Render

# ─── JWT Secrets (use strong random values in production!) ──
ACCESS_TOKEN_SECRET=replace_this_with_strong_random_value
REFRESH_TOKEN_SECRET=replace_this_with_strong_random_value

# ─── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here

# ─── CORS ───────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000      # Change to https://vicas-lab.vercel.app in production

# ─── Database ───────────────────────────────────────────────
DB_FILE=./data/db.sqlite

# ─── Firebase (required for image storage + admin SDK) ──────
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Or use inline JSON (for platforms where you can't upload files):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_STORAGE_BUCKET=vicas-hub.firebasestorage.app

# ─── Email (optional — for BTP weekly reminders) ────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="VICAS Lab" <noreply@vicaslab.com>
# FRONTEND_URL=https://vicas-lab.vercel.app
